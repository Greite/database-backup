# Database backup configuration
#
# Format: CRON_SCHEDULE|TYPE|HOST|PORT|DATABASE|USER|PASSWORD|RETENTION_DAYS|PG_VERSION|TLS
#
# Fields:
#   - CRON_SCHEDULE: Cron expression (e.g. "0 2 * * *" for every day at 2 AM)
#   - TYPE: "postgres", "mariadb" (or "mysql"), or "mongodb"
#   - HOST: Database hostname or IP
#   - PORT: Connection port (optional, default: 5432 for postgres, 3306 for mariadb, 27017 for mongodb)
#   - DATABASE: Name of the database to back up
#   - USER: Connection user (optional for MongoDB without auth)
#   - PASSWORD: Connection password (optional for MongoDB without auth)
#   - RETENTION_DAYS: Number of days to keep backups (optional, default: 7)
#   - PG_VERSION: PostgreSQL client version (optional, default: 18, PostgreSQL only)
#   - TLS: "true" to encrypt the database connection (optional, default: disabled)
#
# Notes:
#   - Empty lines and comments (#) are ignored
#   - Use pipes (|) to separate the fields
#   - Passwords may contain special characters (!@#$%^&*() etc.),
#     EXCEPT the pipe character (|), which is the field separator
#   - No escaping needed, the system automatically handles special characters
#   - This file contains passwords: protect it with "chmod 600 backups.conf"
#   - HOST, DATABASE and USER only accept the characters [A-Za-z0-9._-]

# Example: PostgreSQL backup every day at 2 AM, keep 14 days
0 2 * * *|postgres|postgres-server|5432|myapp_db|backup_user|SecurePassword123|14

# Example: MariaDB backup every day at 3 AM, keep 7 days (default)
0 3 * * *|mariadb|mariadb-server|3306|wordpress|wp_backup|MyS3cretP@ss|7

# Example: PostgreSQL backup every 6 hours, keep 3 days
0 */6 * * *|postgres|pg-production|5432|ecommerce|pg_admin|P@ssw0rd!|3

# Example: MariaDB backup every Sunday at midnight, keep 30 days
0 0 * * 0|mariadb|db.example.com|3306|analytics|readonly_user|backup123|30

# Example: Remote server backup over a TLS connection (PG_VERSION left empty)
0 1 * * *|mariadb|db.example.com|3306|analytics|readonly_user|backup123|30||true

# Example: Remote PostgreSQL backup over TLS
0 1 * * *|postgres|pg.example.com|5432|webapp|backup_user|SecurePass|14|17|true

# Example: Back up multiple databases on the same server
0 4 * * *|postgres|localhost|5432|database1|dbuser|password1|10
0 4 * * *|postgres|localhost|5432|database2|dbuser|password2|10
0 4 * * *|postgres|localhost|5432|database3|dbuser|password3|10

# Example: Password with special characters (!@#$%^&*)
0 5 * * *|mariadb|secure-db|3306|production|admin|ZxirfRuipZPHPc^#V#HFpCpRyrQ!zG5W|30

# Example: MongoDB backup with authentication
0 6 * * *|mongodb|mongo-server|27017|ecommerce|dbadmin|MongoP@ss123|14

# Example: MongoDB backup without authentication (for dev/test)
0 6 * * *|mongodb|localhost|27017|test_db|||7
